      "id": "schedule-003",
      "name": "📅 Monthly Review Scheduler",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [120, 1300]
    },
    {
      "parameters": {
        "jsCode": "// Phase progression checker\nconst phases = [\n  { id: 1, name: 'Discovery & Audit', days: 7, deliverable: 'Discovery Report' },\n  { id: 2, name: 'Strategy & Blueprint', days: 21, deliverable: 'Blueprint Sign-Off' },\n  { id: 3, name: 'Launch & Execute', days: 42, deliverable: 'Live Campaigns + Dashboard' },\n  { id: 4, name: 'Measure & Optimize', days: 70, deliverable: 'Monthly Performance Report' },\n  { id: 5, name: 'Scale & Expand', days: 180, deliverable: 'Expansion Plan' },\n  { id: 6, name: 'Retain & Iterate', days: 999, deliverable: 'Ongoing Retainer' }\n];\n\nconst clientStartDate = new Date($env.CLIENT_START_DATE || new Date());\nconst daysSinceStart = Math.floor((new Date() - clientStartDate) / (1000 * 60 * 60 * 24));\n\nconst currentPhase = phases.find(p => daysSinceStart < p.days) || phases[5];\nconst nextPhase = phases[currentPhase.id] || null;\n\nreturn [{\n  json: {\n    daysSinceStart,\n    currentPhase: currentPhase.name,\n    currentPhaseId: currentPhase.id,\n    currentDeliverable: currentPhase.deliverable,\n    nextPhase: nextPhase?.name || 'Ongoing',\n    progressPercent: Math.min(Math.round((daysSinceStart / (nextPhase?.days || 999)) * 100), 100),\n    isOnTrack: daysSinceStart <= currentPhase.days\n  }\n}];"
      },
      "id": "code-002",
      "name": "🧮 Phase Progress Check",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [360, 1300]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.isOnTrack }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true" }
            }
          ]
        }
      },
      "id": "if-002",
      "name": "🔀 Is On Track?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [600, 1300]
    },
