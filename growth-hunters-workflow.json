      "parameters": {
        "fromEmail": "reports@huntersgrowth.com",
        "toEmail": "={{ $env.CLIENT_EMAILS }}",
        "subject": "=📊 Weekly Growth Report — {{ $json.reportDate }} | {{ $json.status }}",
        "emailType": "html",
        "message": "=<!DOCTYPE html><html><body style='font-family:Inter,sans-serif;background:#0a0f1e;color:#e8edf5;max-width:650px;margin:0 auto;padding:40px 20px;'><div style='text-align:center;margin-bottom:32px;'><h1 style='background:linear-gradient(135deg,#8BC34A,#FFD54F,#26C6DA);-webkit-background-clip:text;-webkit-text-fill-color:transparent;'>📊 Weekly Report</h1><p style='color:#7a7a9a;'>{{ $json.reportDate }}</p></div><div style='display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;'><div style='background:rgba(139,195,74,0.1);border:1px solid rgba(139,195,74,0.3);border-radius:12px;padding:20px;text-align:center;'><p style='color:#8BC34A;font-size:2rem;font-weight:700;margin:0;'>{{ $json.roas }}</p><p style='color:#7a7a9a;margin:4px 0 0;font-size:0.85rem;'>ROAS</p></div><div style='background:rgba(255,213,79,0.1);border:1px solid rgba(255,213,79,0.3);border-radius:12px;padding:20px;text-align:center;'><p style='color:#FFD54F;font-size:2rem;font-weight:700;margin:0;'>{{ $json.conversions }}</p><p style='color:#7a7a9a;margin:4px 0 0;font-size:0.85rem;'>Conversions</p></div><div style='background:rgba(38,198,218,0.1);border:1px solid rgba(38,198,218,0.3);border-radius:12px;padding:20px;text-align:center;'><p style='color:#26C6DA;font-size:2rem;font-weight:700;margin:0;'>{{ $json.sessions }}</p><p style='color:#7a7a9a;margin:4px 0 0;font-size:0.85rem;'>Sessions</p></div><div style='background:rgba(139,195,74,0.1);border:1px solid rgba(139,195,74,0.3);border-radius:12px;padding:20px;text-align:center;'><p style='color:#8BC34A;font-size:2rem;font-weight:700;margin:0;'>{{ $json.revenue }}</p><p style='color:#7a7a9a;margin:4px 0 0;font-size:0.85rem;'>Revenue</p></div></div><div style='background:rgba(255,255,255,0.05);border-radius:12px;padding:20px;text-align:center;'><p style='font-size:1.2rem;font-weight:700;color:#8BC34A;'>{{ $json.status }}</p></div></body></html>"
      },
