      "id": "http-001",
      "name": "📈 Fetch GA4 Analytics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [360, 1000],
      "notes": "جلب بيانات Google Analytics"
    },
    {
      "parameters": {
        "url": "https://graph.facebook.com/v18.0/act_{{ $env.META_AD_ACCOUNT_ID }}/insights",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "facebookGraphApi",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "fields", "value": "spend,impressions,clicks,conversions,cpc,roas" },
            { "name": "date_preset", "value": "last_7d" }
          ]
        }
      },
      "id": "http-002",
      "name": "📢 Fetch Meta Ads Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [360, 1100],
      "notes": "جلب بيانات Meta Ads"
    },
    {
      "parameters": {
        "mode": "combine",
        "combinationMode": "mergeByPosition",
        "options": {}
      },
      "id": "merge-001",
      "name": "🔀 Merge Analytics Data",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [600, 1050]
    },
    {
      "parameters": {
        "jsCode": "const ga4 = $input.all()[0]?.json || {};\nconst meta = $input.all()[1]?.json || {};\n\nconst sessions = ga4?.rows?.[0]?.metricValues?.[0]?.value || 0;\nconst conversions = ga4?.rows?.[0]?.metricValues?.[1]?.value || 0;\nconst revenue = ga4?.rows?.[0]?.metricValues?.[2]?.value || 0;\n\nconst adSpend = meta?.data?.[0]?.spend || 0;\nconst roas = adSpend > 0 ? (revenue / adSpend).toFixed(2) : 0;\nconst cac = conversions > 0 ? (adSpend / conversions).toFixed(2) : 0;\n\nreturn [{\n  json: {\n    period: '7 Days',\n    sessions: parseInt(sessions).toLocaleString(),\n    conversions: parseInt(conversions).toLocaleString(),\n    revenue: '$' + parseFloat(revenue).toFixed(0),\n    adSpend: '$' + parseFloat(adSpend).toFixed(0),\n    roas: roas + 'x',\n    cac: '$' + cac,\n    conversionRate: sessions > 0 ? ((conversions/sessions)*100).toFixed(2) + '%' : '0%',\n    reportDate: new Date().toLocaleDateString('en-GB'),\n    status: roas >= 3 ? '🟢 ON TRACK' : roas >= 2 ? '🟡 NEEDS ATTENTION' : '🔴 CRITICAL'\n  }\n}];"
      },
      "id": "code-001",
      "name": "🧮 Calculate KPIs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [840, 1050]
    },
    {
      "parameters": {
        "channel": "weekly-reports",
        "text": "=📊 *WEEKLY PERFORMANCE REPORT*\n━━━━━━━━━━━━━━━━━━━━\n📅 Period: Last {{ $json.period }}\n📆 Generated: {{ $json.reportDate }}\n\n*🌐 Website Performance:*\n• Sessions: {{ $json.sessions }}\n• Conversions: {{ $json.conversions }}\n• Conversion Rate: {{ $json.conversionRate }}\n• Revenue: {{ $json.revenue }}\n\n*📢 Paid Media Performance:*\n• Ad Spend: {{ $json.adSpend }}\n• ROAS: {{ $json.roas }}\n• CAC: {{ $json.cac }}\n\n*Overall Status: {{ $json.status }}*\n━━━━━━━━━━━━━━━━━━━━\n📋 Full report sent via email",
        "otherOptions": { "icon_emoji": ":bar_chart:", "username": "Growth Hunters Analytics" }
      },
      "id": "slack-003",
      "name": "💬 Slack: Weekly Report",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [1080, 1050]
